  {
    "id": "TC001",
    "title": "Submit route search with valid pickup and destination navigates to results with query params",
    "description": "Verifies that completing both fields and submitting the search navigates to the route comparison results page with origin and destination reflected in the URL.",
    "category": "Multimodal route search",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Lokasi Penjemputan\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Blok M\" into \"Lokasi Penjemputan\" field"
      },
      {
        "type": "action",
        "description": "Type \"Stasiun Sudirman\" into \"Lokasi Tujuan\" field"
      },
      {
        "type": "action",
        "description": "Click on \"Cari Rute Terbaik\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/routes\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"origin=\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"destination=\""
      }
    ]
  },
